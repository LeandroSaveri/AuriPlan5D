{
  "name": "@workspace/auriplan",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "AuriPlan frontend application. React + Vite project using Three.js and React Three Fiber to build a 2D/3D architectural editor with AI tools, template system, furniture library and real-time project workspace. This file defines scripts and dependencies required to run, build and preview the application locally and in production (Vercel).",

  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },

  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.7",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slider": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-tooltip": "^1.2.0",

    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "@react-three/postprocessing": "^3.0.0",

    "axios": "^1.6.2",
    "clipper-lib": "^6.4.2",
    "clsx": "^2.1.1",
    "earcut": "^2.2.4",
    "file-saver": "^2.0.5",
    "framer-motion": "^11.0.0",
    "html2canvas": "^1.4.1",

    "i18next": "^23.7.0",
    "i18next-browser-languagedetector": "^7.2.0",

    "immer": "^10.0.3",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.469.0",

    "rbush": "^3.0.1",

    "react": "^18.3.1",
    "react-dom": "^18.3.1",

    "socket.io-client": "^4.7.4",
    "tailwind-merge": "^2.5.2",

    "three": "^0.169.0",

    "uuid": "^9.0.1",

    "y-websocket": "^1.5.0",
    "yjs": "^13.6.10",

    "zod": "^3.23.8",

    "zustand": "^4.4.7"
  },

  "devDependencies": {
    "@types/earcut": "^2.1.4",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.5.0",
    "@types/rbush": "^3.0.3",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@types/uuid": "^9.0.7",

    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.1",

    "tailwindcss": "^3.4.13",
    "vite": "^5.4.0"
  }
}
