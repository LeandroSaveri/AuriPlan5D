{
  "include": ["src/**/*", "vite.config.ts"],
  "exclude": ["node_modules", "build", "dist", "src/**/*.test.ts", "src/**/*.test.tsx"],
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "dom", "dom.iterable"],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": ["node", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["./src/app/*"],
      "@core/*": ["./src/core/*"],
      "@engine/*": ["./src/engine/*"],
      "@editor/*": ["./src/editor/*"],
      "@features/*": ["./src/features/*"],
      "@components/*": ["./src/components/*"],
      "@ui/*": ["./src/components/ui/*"],
      "@store/*": ["./src/store/*"],
      "@model/*": ["./src/model/*"],
      "@services/*": ["./src/services/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@utils/*": ["./src/utils/*"],
      "@auriplan-types": ["./src/types/index"],
      "@auriplan-types/*": ["./src/types/*"],
      "@workers/*": ["./src/workers/*"],
      "@assets/*": ["./src/assets/*"],
      "@library/*": ["./src/library/*"],
      "@ar/*": ["./src/ar/*"],
      "@rendering/*": ["./src/rendering/*"],
      "@export/*": ["./src/export/*"]
    }
  }
}
